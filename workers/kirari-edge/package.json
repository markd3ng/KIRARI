{
  "name": "@kirari/edge",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "KIRARI Edge runtime — proxy, cache, and API enhancement features for Cloudflare Workers",
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "deploy:dry": "WRANGLER_WRITE_LOGS=false WRANGLER_SEND_METRICS=false wrangler deploy --dry-run --config wrangler.jsonc",
    "deploy": "WRANGLER_WRITE_LOGS=false WRANGLER_SEND_METRICS=false wrangler deploy --config wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "typescript": "^5.9.3",
    "wrangler": "4.106.0"
  },
  "packageManager": "pnpm@9.14.4"
}
