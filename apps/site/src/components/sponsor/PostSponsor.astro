---
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import SharePoster from "./SharePoster.svelte";

interface Props {
	lang?: string;
	post?: {
		title: string;
		author: string;
		description: string;
		pubDate: string;
		url: string;
		siteTitle: string;
		avatar: string;
	};
}

const { lang, post } = Astro.props;
const sponsorText = i18n(I18nKey.sponsorButton, lang);
const cardTitle = post ? i18n(I18nKey.shareOnSocial, lang) : sponsorText;
const cardDesc = post ? i18n(I18nKey.shareOnSocialDescription, lang) : i18n(I18nKey.sponsorButtonText, lang);
---

<div class="rounded-xl bg-[var(--license-block-bg)] px-6 py-5 transition">
	<div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
		<div class="flex items-start gap-3">
			<div class="mt-0.5 flex size-10 shrink-0 items-center justify-center rounded-full bg-[var(--primary)]/10">
				<Icon name="material-symbols:favorite-outline-rounded" class="text-xl text-[var(--primary)]" />
			</div>
			<div>
				<div class="font-bold text-90">{cardTitle}</div>
				<p class="mt-1 text-sm leading-relaxed text-50">{cardDesc}</p>
			</div>
		</div>
		<div class="flex shrink-0 flex-wrap items-center gap-2">
			<SharePoster
				title={post?.title ?? ""}
				author={post?.author ?? ""}
				description={post?.description ?? ""}
				pubDate={post?.pubDate ?? ""}
				url={post?.url ?? ""}
				siteTitle={post?.siteTitle ?? ""}
				avatar={post?.avatar ?? ""}
				client:load
			/>
			<a
				href="/sponsor/"
				class="inline-flex items-center gap-2 whitespace-nowrap rounded-lg bg-[var(--primary)] px-5 py-2.5 text-sm font-medium text-white transition-all hover:bg-[var(--primary)]/80 dark:text-black/70"
			>
				<Icon name="material-symbols:favorite-outline-rounded" class="text-sm" />
				{sponsorText}
				<Icon name="material-symbols:arrow-outward-rounded" class="text-sm" />
			</a>
		</div>
	</div>
</div>
