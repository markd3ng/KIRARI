---
interface Props {
	bvid: string;
	title?: string;
}

const { bvid, title = "Bilibili video" } = Astro.props;
const src = `https://player.bilibili.com/player.html?bvid=${encodeURIComponent(bvid)}&p=1`;
---

<div class="embed-video rounded-xl overflow-hidden border border-[var(--line-divider)]">
	<iframe
		src={src}
		title={title}
		loading="lazy"
		allowfullscreen
		referrerpolicy="strict-origin-when-cross-origin"
		class="w-full aspect-video"
	/>
</div>
