---
import type { GetStaticPaths } from "astro";
import BangumiPanel from "../../components/bangumi/BangumiPanel.astro";
import { bangumiConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { fromLangSlug, getPathAlternates, getPrefixedLanguages, toLangSlug, withLangPrefix } from "../../utils/i18n-utils";

export const getStaticPaths = (() =>
	getPrefixedLanguages().map((lang) => ({
		params: { lang: toLangSlug(lang) },
		props: { lang },
	}))) satisfies GetStaticPaths;

const lang = fromLangSlug(Astro.params.lang);
if (!bangumiConfig.enabled) {
	return Astro.redirect(withLangPrefix("/404/", lang));
}

const title = i18n(I18nKey.bangumi, lang);
const currentUrl = withLangPrefix("/bangumi/", lang);
const alternates = getPathAlternates((itemLang) => withLangPrefix("/bangumi/", itemLang));
---

<MainGridLayout title={title} lang={lang} alternates={alternates} canonicalUrl={currentUrl} toc={false}>
	<BangumiPanel {lang} {title} />
</MainGridLayout>
