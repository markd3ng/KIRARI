---
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getLocalizedSpecEntry } from "@utils/spec-content";
import {
	fromLangSlug,
	getPathAlternates,
	getPrefixedLanguages,
	toLangSlug,
	withLangPrefix,
} from "../../utils/i18n-utils";

export const getStaticPaths = (() =>
	getPrefixedLanguages().map((lang) => ({
		params: { lang: toLangSlug(lang) },
		props: { lang },
	}))) satisfies GetStaticPaths;

const lang = fromLangSlug(Astro.params.lang);
const projectsPage = await getLocalizedSpecEntry("projects", lang);
if (!projectsPage) throw new Error("Projects page content not found");
const { Content } = await render(projectsPage);
const projectsUrl = withLangPrefix("/projects/", lang);
const alternates = getPathAlternates((itemLang) => withLangPrefix("/projects/", itemLang));
---

<MainGridLayout title={i18n(I18nKey.projects, lang)} description={i18n(I18nKey.projects, lang)} lang={lang} alternates={alternates} canonicalUrl={projectsUrl}>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32 mb-4">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<Markdown class="mt-2">
				<Content />
			</Markdown>
		</div>
	</div>
</MainGridLayout>
