---
import type { GetStaticPaths } from "astro";
import Comments from "../../components/comments/Comments.astro";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import MainGridLayout from "../../layouts/MainGridLayout.astro";
import { fromLangSlug, getPathAlternates, getPrefixedLanguages, toLangSlug, withLangPrefix } from "../../utils/i18n-utils";

export const getStaticPaths = (() =>
	getPrefixedLanguages().map((lang) => ({
		params: { lang: toLangSlug(lang) },
		props: { lang },
	}))) satisfies GetStaticPaths;

const lang = fromLangSlug(Astro.params.lang);
const title = "Guestbook";
const currentUrl = withLangPrefix("/guestbook/", lang);
const alternates = getPathAlternates((itemLang) => withLangPrefix("/guestbook/", itemLang));
---

<MainGridLayout title={title} lang={lang} alternates={alternates} canonicalUrl={currentUrl} toc={false}>
	<section class="card-base mb-4 px-6 py-6 md:px-8">
		<h1 class="text-2xl font-bold text-90">{title}</h1>
		<p class="mt-2 text-50">{i18n(I18nKey.comments, lang)}</p>
	</section>
	<Comments path={currentUrl} title={title} lang={lang} />
</MainGridLayout>
