---
import Comments from "../components/comments/Comments.astro";
import { siteConfig } from "../config";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const lang = siteConfig.lang;
const title = "Guestbook";
---

<MainGridLayout title={title} lang={lang} toc={false}>
	<section class="card-base mb-4 px-6 py-6 md:px-8">
		<h1 class="text-2xl font-bold text-90">{title}</h1>
		<p class="mt-2 text-50">{i18n(I18nKey.comments, lang)}</p>
	</section>
	<Comments path="/guestbook/" title={title} lang={lang} />
</MainGridLayout>
