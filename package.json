{
  "name": "kirari",
  "private": true,
  "type": "module",
  "version": "0.3.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markd3ng/KIRARI.git"
  },
  "bugs": {
    "url": "https://github.com/markd3ng/KIRARI/issues"
  },
  "homepage": "https://github.com/markd3ng/KIRARI#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "site:dev": "\"$npm_execpath\" --filter @kirari/site dev",
    "site:build": "\"$npm_execpath\" --filter @kirari/site build",
    "site:type-check": "\"$npm_execpath\" --filter @kirari/site type-check",
    "site:astro-check": "\"$npm_execpath\" --filter @kirari/site check",
    "edge:type-check": "\"$npm_execpath\" --filter @kirari/edge type-check",
    "edge:test": "\"$npm_execpath\" --filter @kirari/edge test",
    "edge:deploy:dry": "\"$npm_execpath\" --filter @kirari/edge deploy:dry",
    "edge:deploy": "\"$npm_execpath\" --filter @kirari/edge deploy",
    "deploy:config:check": "node apps/site/scripts/generate-vercel-config.mjs --check",
    "release:check": "node scripts/release-regression-check.mjs",
    "release:version-check": "node scripts/release-version-check.mjs",
    "check": "\"$npm_execpath\" site:type-check && \"$npm_execpath\" site:astro-check && \"$npm_execpath\" edge:type-check && \"$npm_execpath\" edge:test",
    "build": "\"$npm_execpath\" site:build",
    "audit": "\"$npm_execpath\" --filter @kirari/site audit"
  },
  "packageManager": "pnpm@9.14.4",
  "pnpm": {
    "overrides": {
      "dompurify": "3.4.11",
      "devalue": "5.8.1",
      "esbuild": "0.28.1",
      "js-yaml": "4.2.0",
      "tar": "7.5.16",
      "vite": "7.3.5",
      "ws": "8.21.0",
      "yaml": "2.9.0"
    }
  }
}
