---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import path from "node:path";
import { Icon } from "astro-icon/components";
import Footer from "@components/Footer.astro";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import Navbar from "@components/Navbar.astro";
import { landingPageConfig, profileConfig, siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import Layout from "@/layouts/Layout.astro";
import { getCategoryList, getTaxonomyDisplayMappings } from "@utils/content-utils";
import type { AlternateLink } from "@utils/i18n-utils";
import { getLangHomeUrl, withLangPrefix } from "@utils/i18n-utils";
import { getPostUrl } from "@utils/post-route-utils";
import { getCategoryName, getDir } from "@utils/url-utils";

interface Props {
	posts: CollectionEntry<"posts">[];
	lang: string;
	alternates?: AlternateLink[];
	canonicalUrl?: string;
}

const { posts, lang, alternates, canonicalUrl } = Astro.props;
const latestEntries = posts.slice(0, landingPageConfig.latestCount);
const { tags: tagDisplayMap, categories: categoryDisplayMap } =
	await getTaxonomyDisplayMappings(lang);
const categories = (await getCategoryList(lang))
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name))
	.slice(0, 4);
const latestPosts = await Promise.all(
	latestEntries.map(async (entry) => {
		const { remarkPluginFrontmatter } = await render(entry);
		const imageBasePath = path.join(
			"content/posts/",
			getDir(getDir(entry.id) === "/" ? (entry as any).filePath.replace("src/content/posts/", "") : entry.id),
		);

		return {
			entry,
			url: getPostUrl(entry, lang),
			words: remarkPluginFrontmatter.words,
			minutes: remarkPluginFrontmatter.minutes,
			imageBasePath,
		};
	}),
);

const blogUrl = withLangPrefix("/blog/", lang);
const archiveUrl = withLangPrefix("/archive/", lang);
const aboutUrl = withLangPrefix("/about/", lang);
const friendsUrl = withLangPrefix("/friends/", lang);
const connectLinks = profileConfig.links.slice(0, 3);
const defaultLandingCopy = {
	eyebrow: "WELCOME TO KIRARI",
	title: "Documenting Ideas.",
	highlight: "Sharing Knowledge.",
	description: "A space for notes, tutorials, and thoughts on technology and development.",
	primaryCtaLabel: "Explore Articles",
	secondaryCtaLabel: "Learn More",
};
const defaultFeatureItems = [
	{
		icon: "material-symbols:electric-bolt-rounded",
		title: "Technical Articles",
		description: "In-depth guides and tutorials for developers.",
	},
	{
		icon: "material-symbols:menu-book-outline-rounded",
		title: "Learning Notes",
		description: "Record and share the learning journey.",
	},
	{
		icon: "material-symbols:code-rounded",
		title: "Open Source",
		description: "Build with modern web technologies.",
	},
	{
		icon: "material-symbols:favorite-outline-rounded",
		title: "Community",
		description: "Connect and grow together.",
	},
];

const localizedLandingCopy = {
	"en-US": {
		...defaultLandingCopy,
		latestEyebrow: "Latest Updates",
		latestTitle: "Latest Articles",
		viewAllArticles: "View All Articles",
		brandDescription: "Documenting ideas and sharing knowledge. Built with care and modern web technologies.",
		navigation: "Navigation",
		blog: "Blog",
		connect: "Connect",
		readTime: (minutes: number) => `${minutes} ${minutes === 1 ? "minute" : "minutes"} read`,
		features: [
			["Technical Articles", "In-depth guides and tutorials for developers."],
			["Learning Notes", "Record and share the learning journey."],
			["Open Source", "Build with modern web technologies."],
			["Community", "Connect and grow together."],
		],
	},
	"zh-CN": {
		eyebrow: "欢迎来到 KIRARI",
		title: "记录灵感。",
		highlight: "分享知识。",
		description: "这里记录技术笔记、教程，以及关于开发与工程实践的思考。",
		primaryCtaLabel: "浏览文章",
		secondaryCtaLabel: "了解更多",
		latestEyebrow: "最新动态",
		latestTitle: "最新文章",
		viewAllArticles: "查看全部文章",
		brandDescription: "记录想法，分享知识。用现代 Web 技术认真构建。",
		navigation: "导航",
		blog: "博客",
		connect: "联系",
		readTime: (minutes: number) => `${minutes} 分钟阅读`,
		features: [
			["技术文章", "面向开发者的深度指南与教程。"],
			["学习笔记", "记录并分享持续学习的过程。"],
			["开源实践", "基于现代 Web 技术进行构建。"],
			["社区交流", "连接彼此，共同成长。"],
		],
	},
	"zh-TW": {
		eyebrow: "歡迎來到 KIRARI",
		title: "記錄靈感。",
		highlight: "分享知識。",
		description: "這裡記錄技術筆記、教學，以及關於開發與工程實踐的思考。",
		primaryCtaLabel: "瀏覽文章",
		secondaryCtaLabel: "了解更多",
		latestEyebrow: "最新動態",
		latestTitle: "最新文章",
		viewAllArticles: "查看全部文章",
		brandDescription: "記錄想法，分享知識。用現代 Web 技術用心構建。",
		navigation: "導覽",
		blog: "部落格",
		connect: "連結",
		readTime: (minutes: number) => `${minutes} 分鐘閱讀`,
		features: [
			["技術文章", "面向開發者的深度指南與教學。"],
			["學習筆記", "記錄並分享持續學習的過程。"],
			["開源實踐", "基於現代 Web 技術進行構建。"],
			["社群交流", "連結彼此，共同成長。"],
		],
	},
};

const activeLandingLocale = lang === "zh-CN" ? "zh-CN" : lang === "zh-TW" || lang === "zh-HK" ? "zh-TW" : "en-US";
const localizedCopy = localizedLandingCopy[activeLandingLocale];
const copy = {
	...localizedCopy,
	eyebrow: landingPageConfig.eyebrow === defaultLandingCopy.eyebrow ? localizedCopy.eyebrow : landingPageConfig.eyebrow,
	title: landingPageConfig.title === defaultLandingCopy.title ? localizedCopy.title : landingPageConfig.title,
	highlight: landingPageConfig.highlight === defaultLandingCopy.highlight ? localizedCopy.highlight : landingPageConfig.highlight,
	description: landingPageConfig.description === defaultLandingCopy.description ? localizedCopy.description : landingPageConfig.description,
	primaryCtaLabel: landingPageConfig.primaryCtaLabel === defaultLandingCopy.primaryCtaLabel ? localizedCopy.primaryCtaLabel : landingPageConfig.primaryCtaLabel,
	secondaryCtaLabel: landingPageConfig.secondaryCtaLabel === defaultLandingCopy.secondaryCtaLabel ? localizedCopy.secondaryCtaLabel : landingPageConfig.secondaryCtaLabel,
};
const usesDefaultFeatures =
	landingPageConfig.features.items.length === defaultFeatureItems.length &&
	landingPageConfig.features.items.every((feature, index) => {
		const defaultFeature = defaultFeatureItems[index];
		return (
			feature.icon === defaultFeature.icon &&
			feature.title === defaultFeature.title &&
			feature.description === defaultFeature.description
		);
	});
const features = usesDefaultFeatures
	? copy.features.map(([title, description], index) => ({
			icon: defaultFeatureItems[index].icon,
			title,
			description,
		}))
	: landingPageConfig.features.items;
const wordLabel = (count: number) => i18n(count === 1 ? I18nKey.wordCount : I18nKey.wordsCount, lang);
---

	<Layout
	title={siteConfig.title}
	description={copy.description}
	lang={lang}
	alternates={alternates}
	canonicalUrl={canonicalUrl || getLangHomeUrl(lang)}
>
	<div class="kirari-landing min-h-screen">
		<div class="landing-field" aria-hidden="true" transition:animate="none">
			<div class="landing-stars"></div>
			<div class="landing-glow landing-glow-a"></div>
			<div class="landing-glow landing-glow-b"></div>
		</div>

		<header class="pointer-events-none sticky top-0 z-50 mx-auto max-w-[var(--page-width)] px-0 md:px-4" transition:name="navbar">
			<div id="navbar-wrapper" class="pointer-events-auto transition-[opacity,transform]">
				<Navbar lang={lang} alternates={alternates} showSearch={false} variant="landing"></Navbar>
			</div>
		</header>

		<main id="swup-container" class="transition-swup-fade relative z-10">
			<section class="landing-hero mx-auto grid max-w-[var(--page-width)] grid-cols-1 items-center gap-10 px-4 pb-7 pt-6 md:px-4 lg:grid-cols-[0.45fr_0.55fr] lg:gap-8 lg:pb-4 lg:pt-10">
				<div class="landing-fade-up">
					<p class="mb-5 text-sm font-bold uppercase tracking-[0.18em] text-[var(--landing-accent)]">
						{copy.eyebrow}
					</p>
					<h1 class="max-w-[38rem] text-5xl font-extrabold leading-[1.02] tracking-normal text-[var(--landing-text-primary)] md:text-6xl lg:text-[4rem]">
						<span>{copy.title}</span>
						<span class="mt-2 block bg-[linear-gradient(90deg,var(--landing-accent),var(--landing-accent-strong),var(--landing-accent-soft))] bg-clip-text text-transparent">
							{copy.highlight}
						</span>
					</h1>
					<p class="mt-6 max-w-[30rem] text-base leading-8 text-[var(--landing-text-secondary)] md:text-lg">
						{copy.description}
					</p>
					<div class="mt-9 flex flex-col gap-4 sm:flex-row">
						<a href={blogUrl} data-astro-prefetch="hover" class="landing-primary-btn">
							<span>{copy.primaryCtaLabel}</span>
							<Icon name="material-symbols:chevron-right-rounded" class="text-xl" />
						</a>
						<a href={aboutUrl} data-astro-prefetch="hover" class="landing-secondary-btn">
							<span>{copy.secondaryCtaLabel}</span>
							<Icon name="material-symbols:chevron-right-rounded" class="text-xl" />
						</a>
					</div>
				</div>

				<div class="landing-hero-art landing-fade-up lg:mt-8" style="animation-delay: 120ms">
					<div class="hero-art-shell">
						<div class="hero-art-glow"></div>
						<ImageWrapper
							src={landingPageConfig.heroImage}
							alt={`${siteConfig.title} hero illustration`}
							class="hero-art-image"
							loading="eager"
							decoding="sync"
							fetchpriority="high"
							sizes="(min-width: 1024px) 56vw, 100vw"
							widths={[480, 640, 828, 1080, 1280, 1600]}
							quality={74}
						/>
						<div class="hero-art-shine"></div>
					</div>
				</div>
			</section>

			{landingPageConfig.features.enable && features.length > 0 && (
				<section class="mx-auto max-w-[var(--page-width)] px-4 pb-5 md:px-4">
					<div class="landing-feature-grid">
						{features.map((feature, index) => (
							<article class="landing-feature-card landing-fade-up" style={`animation-delay: ${180 + index * 70}ms`}>
								<div class="landing-feature-icon">
									<Icon name={feature.icon} class="text-2xl" />
								</div>
								<h2>{feature.title}</h2>
								<p>{feature.description}</p>
							</article>
						))}
					</div>
				</section>
			)}

			<section class="mx-auto max-w-[var(--page-width)] px-4 pb-10 pt-6 md:px-4">
				<div class="mb-7 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.18em] text-[var(--landing-accent)]">{copy.latestEyebrow}</p>
						<h2 class="mt-2 text-3xl font-extrabold text-[var(--landing-text-primary)]">{copy.latestTitle}</h2>
					</div>
					<a href={blogUrl} data-astro-prefetch="hover" class="landing-text-link">
						<span>{copy.viewAllArticles}</span>
						<Icon name="material-symbols:chevron-right-rounded" class="text-xl" />
					</a>
				</div>

				<div class="flex flex-col gap-4">
					{latestPosts.map(({ entry, url, words, minutes, imageBasePath }, index) => (
						<article class="landing-article-card landing-fade-up" style={`animation-delay: ${index * 80}ms`}>
							<a href={url} aria-label={entry.data.title} data-astro-prefetch="hover" class="landing-article-cover">
								{entry.data.image ? (
									<ImageWrapper
										src={entry.data.image}
										basePath={imageBasePath}
										alt={`Cover image of ${entry.data.title}`}
										class="h-full w-full"
										loading="lazy"
										sizes="(min-width: 768px) 240px, 100vw"
										widths={[320, 480, 640]}
										quality={68}
									/>
								) : (
									<div class="landing-article-fallback">
										<Icon name="material-symbols:article-outline-rounded" class="text-4xl" />
									</div>
								)}
							</a>
							<div class="min-w-0 flex-1">
								<div class="mb-3 flex flex-wrap items-center gap-2 text-xs font-medium text-[var(--landing-text-muted)]">
									<span>{entry.data.published.toISOString().slice(0, 10)}</span>
									<span>/</span>
									<span>{getCategoryName(entry.data.category || "uncategorized", categoryDisplayMap)}</span>
									{entry.data.tags.slice(0, 4).map((tag) => (
										<span class="landing-tag">{tagDisplayMap[tag] || tag}</span>
									))}
								</div>
								<a href={url} data-astro-prefetch="hover" class="group block">
									<h3 class="line-clamp-2 text-xl font-bold text-[var(--landing-text-primary)] transition group-hover:text-[var(--landing-accent)]">
										{entry.data.title}
									</h3>
								</a>
								<p class="mt-2 line-clamp-2 text-sm leading-6 text-[var(--landing-text-secondary)]">
									{entry.data.description}
								</p>
								<div class="mt-3 flex gap-3 text-xs text-[var(--landing-text-muted)]">
									<span>{words} {wordLabel(words)}</span>
									<span>|</span>
									<span>{copy.readTime(minutes)}</span>
								</div>
							</div>
							<a href={url} aria-label={`Read ${entry.data.title}`} data-astro-prefetch="hover" class="landing-article-arrow">
								<Icon name="material-symbols:chevron-right-rounded" class="text-2xl" />
							</a>
						</article>
					))}
				</div>
			</section>

			<footer class="mx-auto max-w-[var(--page-width)] px-4 pb-12 pt-8 md:px-4">
				<div class="landing-footer">
					<div>
						<a href={getLangHomeUrl(lang)} data-landing-home-link class="inline-flex items-center gap-2 text-lg font-extrabold text-[var(--landing-accent)]">
							<Icon name="material-symbols:home-outline-rounded" class="text-2xl" />
							{siteConfig.title}
						</a>
						<p class="mt-4 max-w-[18rem] text-sm leading-6 text-[var(--landing-text-secondary)]">
							{copy.brandDescription}
						</p>
						<div class="mt-5 flex gap-3">
							{connectLinks.map((link) => (
								<a href={link.url} aria-label={link.name} target="_blank" rel="noopener noreferrer" class="landing-social-link">
									<span>{link.name.slice(0, 1).toUpperCase()}</span>
								</a>
							))}
						</div>
					</div>
					<div>
						<h3>{copy.navigation}</h3>
						<a href={getLangHomeUrl(lang)} data-astro-prefetch="hover" data-landing-home-link>{i18n(I18nKey.home, lang)}</a>
						<a href={blogUrl} data-astro-prefetch="hover">{copy.blog}</a>
						<a href={archiveUrl} data-astro-prefetch="hover">{i18n(I18nKey.archive, lang)}</a>
						<a href={aboutUrl} data-astro-prefetch="hover">{i18n(I18nKey.about, lang)}</a>
						<a href={friendsUrl} data-astro-prefetch="hover">{i18n(I18nKey.friends, lang)}</a>
					</div>
					<div>
						<h3>{i18n(I18nKey.categories, lang)}</h3>
						{categories.map((category) => (
							<a href={category.url} data-astro-prefetch="hover">
								{getCategoryName(category.name, categoryDisplayMap)}
							</a>
						))}
					</div>
					<div>
						<h3>{copy.connect}</h3>
						{connectLinks.map((link) => (
							<a href={link.url} target="_blank" rel="noopener noreferrer">{link.name}</a>
						))}
					</div>
				</div>
				<Footer lang={lang}></Footer>
			</footer>
		</main>
	</div>
</Layout>

<script>
	import { transitionManager } from "@utils/transition-manager";

	function normalizePath(path: string) {
		return path.replace(/\/+$/, "") || "/";
	}

	function scrollLandingToTop() {
		const overlayViewport = document.querySelector("[data-overlayscrollbars-viewport]") as HTMLElement | null;
		overlayViewport?.scrollTo({ top: 0, behavior: "smooth" });
		window.scrollTo({ top: 0, behavior: "smooth" });
		document.documentElement.scrollTop = 0;
		document.body.scrollTop = 0;
	}

	function bindLandingHomeLinks() {
		document.querySelectorAll<HTMLAnchorElement>("[data-landing-home-link]").forEach((link) => {
			if (link.dataset.landingHomeBound === "true") return;
			link.dataset.landingHomeBound = "true";
			link.addEventListener("click", (event) => {
				const target = new URL(link.href, window.location.href);
				const samePage =
					target.origin === window.location.origin &&
					normalizePath(target.pathname) === normalizePath(window.location.pathname) &&
					!target.hash;

				if (!samePage) return;
				event.preventDefault();
				scrollLandingToTop();
			});
		});
	}

	bindLandingHomeLinks();
	transitionManager.on("transition:after-swap", bindLandingHomeLinks);
</script>

<style>
	.kirari-landing {
		--landing-hue-primary: oklch(0.62 0.18 var(--hue));
		--landing-hue-primary-hover: oklch(0.7 0.16 var(--hue));
		--landing-hue-primary-strong: oklch(0.54 0.2 var(--hue));
		--landing-hue-primary-soft: oklch(0.78 0.13 var(--hue));
		--landing-page-bg:
			radial-gradient(circle at 75% 12%, oklch(0.62 0.18 var(--hue) / 0.18), transparent 30rem),
			radial-gradient(circle at 12% 38%, oklch(0.74 0.13 calc(var(--hue) + 28) / 0.12), transparent 28rem),
			linear-gradient(180deg, #f8fbff 0%, #eef6ff 48%, #f6fbff 100%);
		--landing-field-bg: var(--landing-page-bg);
		--landing-star-primary: rgba(15, 23, 42, 0.38);
		--landing-star-secondary: oklch(0.68 0.15 var(--hue) / 0.62);
		--landing-star-opacity: 0.2;
		--landing-star-mask: linear-gradient(to bottom, black 0%, black 68%, transparent 100%);
		--landing-glow-a: oklch(0.62 0.18 var(--hue) / 0.22);
		--landing-glow-b: oklch(0.68 0.13 calc(var(--hue) + 52) / 0.1);
		--landing-text-primary: #0f172a;
		--landing-text-secondary: #475569;
		--landing-text-muted: #64748b;
		--landing-accent: var(--landing-hue-primary);
		--landing-accent-strong: var(--landing-hue-primary-strong);
		--landing-accent-soft: var(--landing-hue-primary-soft);
		--landing-border: rgba(15, 23, 42, 0.1);
		--landing-border-strong: oklch(0.62 0.18 var(--hue) / 0.28);
		--landing-surface: rgba(255, 255, 255, 0.64);
		--landing-surface-hover: rgba(255, 255, 255, 0.8);
		--landing-surface-shadow: 0 16px 42px oklch(0.62 0.18 var(--hue) / 0.12);
		--landing-surface-shadow-hover: 0 18px 48px oklch(0.62 0.18 var(--hue) / 0.18);
		--landing-secondary-btn-bg: rgba(255, 255, 255, 0.56);
		--landing-secondary-btn-text: rgba(15, 23, 42, 0.82);
		--landing-hero-border: oklch(0.62 0.18 var(--hue) / 0.18);
		--landing-hero-bg: rgba(255, 255, 255, 0.5);
		--landing-hero-shadow: 0 18px 48px oklch(0.62 0.18 var(--hue) / 0.16), 0 0 60px oklch(0.62 0.18 var(--hue) / 0.16);
		--landing-hero-glow: oklch(0.7 0.16 var(--hue) / 0.36);
		--landing-hero-shine:
			linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent 28%),
			radial-gradient(circle at 74% 18%, oklch(0.62 0.18 var(--hue) / 0.14), transparent 12rem);
		--landing-icon-bg: oklch(0.62 0.18 var(--hue) / 0.12);
		--landing-cover-bg: oklch(0.62 0.18 var(--hue) / 0.08);
		--landing-fallback-bg: radial-gradient(circle at 50% 20%, oklch(0.7 0.16 var(--hue) / 0.28), oklch(0.95 0.04 var(--hue) / 0.92));
		--landing-tag-border: oklch(0.62 0.18 var(--hue) / 0.2);
		--landing-arrow-hover-bg: oklch(0.62 0.18 var(--hue) / 0.1);
		--landing-social-bg: oklch(0.62 0.18 var(--hue) / 0.1);
		--landing-social-text: var(--landing-hue-primary);
		--landing-social-hover-bg: oklch(0.62 0.18 var(--hue) / 0.18);
		--landing-footer-base-text: rgba(15, 23, 42, 0.62);
		--landing-footer-base-border: rgba(15, 23, 42, 0.08);
		--landing-nav-bg: rgba(255, 255, 255, 0.76);
		--landing-nav-text: rgba(15, 23, 42, 0.74);
		--landing-nav-hover: var(--landing-hue-primary);
		--landing-nav-hover-bg: oklch(0.62 0.18 var(--hue) / 0.1);
		--landing-nav-active-bg: oklch(0.62 0.18 var(--hue) / 0.16);
		--landing-nav-border: rgba(15, 23, 42, 0.08);
		--landing-nav-shadow: 0 14px 34px oklch(0.62 0.18 var(--hue) / 0.12);
		--landing-primary-btn-bg: linear-gradient(135deg, var(--landing-hue-primary-hover), var(--landing-hue-primary-strong));
		--landing-primary-btn-text: #ffffff;
		--landing-primary-btn-shadow: 0 16px 34px oklch(0.62 0.18 var(--hue) / 0.28);
		--landing-btn-hover-shadow: 0 18px 40px oklch(0.62 0.18 var(--hue) / 0.24);
		position: relative;
		overflow: hidden;
		background: var(--landing-page-bg);
		color: var(--landing-text-primary);
		color-scheme: light;
		isolation: isolate;
