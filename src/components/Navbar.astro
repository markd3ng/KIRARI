---
import { Icon } from "astro-icon/components";
import { navBarConfig, searchConfig, siteConfig } from "../config";
import { getLinkPreset } from "../constants/link-presets";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { type LinkPresetType, type NavBarLink } from "../types/config";
import type { AlternateLink } from "../utils/i18n-utils";
import { getLangHomeUrl, withLangPrefix } from "../utils/i18n-utils";
import { url } from "../utils/url-utils";
import LanguageSwitch from "./LanguageSwitch.astro";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;
const lang = Astro.props.lang;
const alternates = Astro.props.alternates as AlternateLink[] | undefined;
const showSearch = Astro.props.showSearch !== false;
const variant = Astro.props.variant || "default";
const isLandingVariant = variant === "landing";

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPresetType): NavBarLink => {
		if (typeof item === "number") {
			return getLinkPreset(item, lang);
		}
		return item;
	},
);

const themeIcons = [
	{ mode: "light", icon: "material-symbols:wb-sunny-outline-rounded" },
	{ mode: "dark", icon: "material-symbols:dark-mode-outline-rounded" },
	{ mode: "auto", icon: "material-symbols:radio-button-partial-outline" },
];

const resolveNavUrl = (link: NavBarLink) => {
	if (link.external) return link.url;
	return lang ? withLangPrefix(link.url, lang) : url(link.url);
};
const searchLabel = i18n(I18nKey.search, lang);
const themeLabel = `${i18n(I18nKey.lightMode, lang)} / ${i18n(I18nKey.darkMode, lang)}`;
const displaySettingsLabel = i18n(I18nKey.themeColor, lang);
const docsearchConfig = {
	enable: !!searchConfig.docsearch.enable &&
		!!searchConfig.docsearch.appId &&
		!!searchConfig.docsearch.apiKey &&
		!!searchConfig.docsearch.indexName,
	appId: searchConfig.docsearch.appId,
	apiKey: searchConfig.docsearch.apiKey,
	indexName: searchConfig.docsearch.indexName,
	filterByLanguage: searchConfig.docsearch.filterByLanguage,
};
---
<div id="navbar" class="z-50 onload-animation">
    <div class:list={[
        "absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition",
        { "navbar-landing-fill": isLandingVariant },
    ]}></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base !overflow-visible max-w-[var(--page-width)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4",
        { "navbar-landing backdrop-blur-xl border": isLandingVariant },
    ]}>
        <a href={lang ? getLangHomeUrl(lang) : url('/')} aria-label="Home" data-astro-prefetch="hover" class="btn-plain scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95">
            <div class="flex flex-row text-[var(--primary)] items-center text-md">
                <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                {siteConfig.title}
            </div>
        </a>
        <div class="hidden md:flex">
            {links.map((l) => {
                return <a href={resolveNavUrl(l)} target={l.external ? "_blank" : null}
                          aria-label={l.name}
                          data-astro-prefetch={l.external ? undefined : "hover"}
                          class="btn-plain scale-animation rounded-lg h-11 font-bold px-5 active:scale-95"
                >
                    <div class="flex items-center">
                        {l.name}
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"></Icon>}
                    </div>
                </a>;
            })}
        </div>
        <div class="flex">
            <!-- Search bar for desktop - instant display with Astro icons -->
            <div id="search-bar" class:list={[
                "hidden lg:flex transition-all items-center h-11 mr-2 rounded-lg bg-black/[0.04] hover:bg-black/[0.06] focus-within:bg-black/[0.06] dark:bg-white/5 dark:hover:bg-white/10 dark:focus-within:bg-white/10",
                { "lg:!hidden": !showSearch },
            ]}>
                <Icon name="material-symbols:search" class="absolute text-[1.25rem] pointer-events-none ml-3 transition my-auto text-black/30 dark:text-white/30" />
                <input id="search-input-desktop" placeholder={searchLabel} aria-label={searchLabel}
                    class="transition-all pl-10 text-sm bg-transparent outline-0
                    h-full w-40 active:w-60 focus:w-60 text-black/50 dark:text-white/50"
                />
            </div>

            <!-- Search toggle button for mobile - instant display -->
            {showSearch && (
                <button type="button" aria-label={searchLabel} id="search-switch" aria-controls="search-panel" aria-expanded="false" aria-haspopup="dialog"
                    class="btn-plain scale-animation lg:!hidden rounded-lg w-11 h-11 active:scale-90">
                    <Icon name="material-symbols:search" class="text-[1.25rem]" />
                </button>
            )}

            {showSearch && <Search lang={lang} docsearch={docsearchConfig} client:idle></Search>}
            {!siteConfig.themeColor.fixed && (
                    <button type="button" aria-label={displaySettingsLabel} aria-controls="display-setting" aria-expanded="false" aria-haspopup="dialog" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <!-- z-50 make the panel higher than other float panels -->
            <div class="relative z-50" id="theme-switch-wrapper">
                <button type="button" aria-label={themeLabel} aria-controls="light-dark-panel" aria-haspopup="menu" class="relative btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="scheme-switch">
                    {themeIcons.map(({ mode, icon }) => (
                        <div class={`absolute theme-icon-${mode}`}>
                            <Icon name={icon} class="text-[1.25rem]" />
                        </div>
                    ))}
                </button>
                <LightDarkSwitch lang={lang} client:idle></LightDarkSwitch>
            </div>
            <LanguageSwitch currentLang={lang} alternates={alternates}></LanguageSwitch>
            <button type="button" aria-label="Menu" name="Nav Menu" aria-controls="nav-menu-panel" aria-expanded="false" aria-haspopup="menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links} lang={lang}></NavMenuPanel>
        <DisplaySettings lang={lang} client:only="svelte"></DisplaySettings>
    </div>
</div>

<script>
function setExpandedState(button: HTMLElement | null, panel: HTMLElement | null) {
	if (!button || !panel) return;
	button.setAttribute("aria-expanded", String(!panel.classList.contains("float-panel-closed")));
}

function bindPanelToggle(buttonId: string, panelId: string) {
	const button = document.getElementById(buttonId);
	const panel = document.getElementById(panelId);
	if (!button || !panel) return;
	if ((button as HTMLElement).dataset.boundPanelId === panelId) return;
	(button as HTMLElement).dataset.boundPanelId = panelId;

	setExpandedState(button, panel);
	button.onclick = function () {
		panel.classList.toggle("float-panel-closed");
		setExpandedState(button, panel);
	};
}

function loadButtonScript() {
	bindPanelToggle("display-settings-switch", "display-setting");
	bindPanelToggle("nav-menu-switch", "nav-menu-panel");
	bindPanelToggle("language-switch", "language-panel");
}

// Make function globally accessible for re-initialization after page transitions
(window as any).loadNavbarButtons = loadButtonScript;

document.addEventListener("display-settings:ready", loadButtonScript);
loadButtonScript();
</script>

<style>
    .navbar-landing-fill {
        background: var(--landing-nav-bg) !important;
    }

    .navbar-landing {
        background: var(--landing-nav-bg) !important;
        border-color: var(--landing-nav-border) !important;
        box-shadow: var(--landing-nav-shadow) !important;
        color: var(--landing-nav-text);
    }

    .navbar-landing .btn-plain {
        color: var(--landing-nav-text);
    }

    .navbar-landing .btn-plain:hover,
    .navbar-landing .btn-plain:focus-visible {
        color: var(--landing-nav-hover);
    }

    .navbar-landing .btn-plain::before {
        background: transparent;
    }

    .navbar-landing .btn-plain:hover::before {
        background: var(--landing-nav-hover-bg);
    }

    .navbar-landing .btn-plain:active::before {
        background: var(--landing-nav-active-bg);
    }

    html[data-theme-effective="light"] .theme-icon-dark,
    html[data-theme-effective="light"] .theme-icon-auto,
    html[data-theme-effective="dark"] .theme-icon-light,
    html[data-theme-effective="dark"] .theme-icon-auto {
        display: none;
    }
</style>
