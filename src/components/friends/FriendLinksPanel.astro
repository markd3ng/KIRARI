---
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

type FriendItem = {
	siteTitle: string;
	siteDesc: string;
	siteUrl: string;
	siteIcon: string;
	tags?: string[];
	weight?: number;
	enabled?: boolean;
};

interface Props {
	items: FriendItem[];
	lang?: string;
}

const { items, lang } = Astro.props;
const isZh = lang?.startsWith("zh");
const copy = isZh
	? {
			description: "这里是我的朋友们，欢迎互相访问交流",
			searchPlaceholder: "搜索友链...",
			all: "全部",
			noFriends: "还没有可显示的友链",
			noResults: "没有找到匹配的友链",
			applyTitle: "申请友链",
			applyIntro: "把下面的信息添加到你的友链页后，再通过评论或邮件告诉我。",
			siteName: "站点名称",
			siteDescription: "站点描述",
			siteUrl: "站点链接",
			avatarUrl: "头像链接",
			copy: "复制",
			copied: "已复制",
			templateTitle: "申请模板",
			steps: [
				["添加本站友链", "请先在您的网站友链页面添加本站信息，可直接复制左侧各字段"],
				["留言或发送申请", "把申请模板复制修改后，通过评论区或邮件发送"],
				["等待审核", "确认信息无误后会尽快添加您的友链"],
			],
			notices: [
				["互换原则", "请先将本站添加到您的友链页面，确认后会添加您的友链"],
				["链接维护", "友链网站长期无法访问或内容违规，将会被移除"],
				["内容要求", "内容积极向上，不含色情、暴力、反动等违法违规内容"],
				["站点要求", "支持 HTTPS，以原创内容为主，能够正常访问且有持续更新"],
			],
		}
	: {
			description: "A small circle of friends and sites worth visiting.",
			searchPlaceholder: "Search friends...",
			all: "All",
			noFriends: "No friend links yet",
			noResults: "No friend links matched",
			applyTitle: "Apply for a friend link",
			applyIntro: "Add this site to your friends page first, then send your details by comment or email.",
			siteName: "Site name",
			siteDescription: "Site description",
			siteUrl: "Site URL",
			avatarUrl: "Avatar URL",
			copy: "Copy",
			copied: "Copied",
			templateTitle: "Application template",
			steps: [
				["Add this site", "Add this site to your friend links page first. You can copy the fields on the left."],
				["Send your request", "Copy and edit the template, then send it by comment or email."],
				["Wait for review", "Your link will be added after the information is checked."],
			],
			notices: [
				["Reciprocal link", "Please add this site to your friends page before applying."],
				["Maintenance", "Unavailable or policy-violating sites may be removed."],
				["Content", "Keep content positive and free of illegal or harmful material."],
				["Site quality", "HTTPS, original content, normal access, and ongoing updates are preferred."],
			],
		};

const enabledItems = items
	.filter((item) => item.enabled !== false)
	.sort((a, b) => (b.weight ?? 0) - (a.weight ?? 0) || a.siteTitle.localeCompare(b.siteTitle));
const allTags = Array.from(new Set(enabledItems.flatMap((item) => item.tags ?? []))).sort((a, b) => a.localeCompare(b));
const applicationFields = [
	[copy.siteName, profileConfig.name],
	[copy.siteDescription, profileConfig.bio],
	[copy.siteUrl, siteConfig.url],
	[copy.avatarUrl, profileConfig.avatar],
].filter(([, value]) => Boolean(value));
const applicationTemplate = [
	`${copy.siteName}: ${isZh ? "您的站点名称" : "Your site name"}`,
	`${copy.siteDescription}: ${isZh ? "您的站点描述" : "Your site description"}`,
	`${copy.siteUrl}: ${isZh ? "您的站点链接" : "Your site URL"}`,
	`${copy.avatarUrl}: ${isZh ? "您的站点头像" : "Your site avatar"}`,
].join("\n");
const applySteps = copy.steps;
const noticeItems = copy.notices;
---

<section class="card-base relative overflow-hidden px-6 py-6 sm:px-9" aria-labelledby="friends-title">
	<div class="mb-6">
		<div class="mb-3 flex items-center gap-3">
			<div class="flex h-11 w-11 items-center justify-center rounded-lg bg-[var(--primary)] text-white dark:text-black/75">
				<Icon name="material-symbols:group" class="text-3xl" />
			</div>
			<h1 id="friends-title" class="text-3xl font-extrabold text-90 sm:text-4xl">{i18n(I18nKey.friends, lang)}</h1>
		</div>
		<p class="text-base font-medium text-50">{copy.description}</p>
	</div>

	{enabledItems.length > 0 ? (
		<friend-filter class="block">
			<div class="relative mb-4">
				<Icon name="material-symbols:search" class="pointer-events-none absolute left-4 top-1/2 text-xl text-30 -translate-y-1/2" />
				<input
					type="search"
					data-friend-search
					placeholder={copy.searchPlaceholder}
					class="h-14 w-full rounded-xl border border-black/10 bg-transparent pl-12 pr-4 text-base font-medium text-75 outline-none transition placeholder:text-30 focus:border-[var(--primary)] focus:ring-2 focus:ring-[color-mix(in_oklab,var(--primary)_28%,transparent)] dark:border-white/10"
				/>
			</div>

			<div class="mb-6 flex flex-wrap gap-2" aria-label="Friend link categories">
				<button type="button" data-friend-tag="all" aria-pressed="true" class="friend-filter-chip is-active">{copy.all}</button>
				{allTags.map((tag) => (
					<button type="button" data-friend-tag={tag} aria-pressed="false" class="friend-filter-chip">{tag}</button>
				))}
			</div>

			<div class="friends-grid">
				{enabledItems.map((item) => {
					const tags = item.tags ?? [];
					const searchText = [item.siteTitle, item.siteDesc, item.siteUrl, ...tags].join(" ").toLowerCase();
					return (
						<a
							href={item.siteUrl}
							target="_blank"
							rel="noopener noreferrer"
							data-friend-card
							data-tags={tags.join(",")}
							data-search-text={searchText}
							class="group relative flex min-h-28 items-center gap-4 overflow-hidden rounded-xl border border-black/10 p-3 transition duration-300 hover:border-[var(--primary)] hover:bg-[color-mix(in_oklab,var(--primary)_8%,transparent)] dark:border-white/10"
						>
							<div class="absolute inset-0 bg-[var(--primary)] opacity-0 transition duration-300 group-hover:opacity-[0.04]"></div>
							<div class="relative h-20 w-20 shrink-0 overflow-hidden rounded-xl border border-black/5 bg-black/5 dark:border-white/5 dark:bg-white/5">
								<img src={item.siteIcon} alt={item.siteTitle} width="80" height="80" loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
							</div>
							<div class="relative min-w-0 grow">
								<div class="mb-1 flex items-center gap-2">
									<h2 class="truncate text-lg font-extrabold text-90 transition group-hover:text-[var(--primary)]">{item.siteTitle}</h2>
									<Icon name="material-symbols:arrow-outward-rounded" class="shrink-0 text-xl text-[var(--primary)] opacity-0 transition group-hover:opacity-100" />
								</div>
								<p class="line-clamp-1 text-sm font-medium text-50" title={item.siteDesc}>{item.siteDesc}</p>
								{tags.length > 0 && (
									<div class="mt-2 flex flex-wrap gap-1">
										{tags.slice(0, 3).map((tag) => (
											<span class="rounded-md bg-black/[0.06] px-2 py-0.5 text-xs font-bold text-50 dark:bg-white/[0.08]">{tag}</span>
										))}
									</div>
								)}
							</div>
						</a>
					);
				})}
			</div>
			<div data-friend-empty class="hidden flex-col items-center justify-center py-10 text-50">
				<Icon name="material-symbols:search-off-rounded" class="mb-2 text-4xl" />
				<div class="text-sm font-bold">{copy.noResults}</div>
			</div>
		</friend-filter>
	) : (
		<div class="flex flex-col items-center justify-center py-12 text-50">
			<Icon name="material-symbols:group-off-outline" class="mb-2 text-4xl" />
			<div class="text-sm font-bold">{copy.noFriends}</div>
		</div>
	)}
</section>

<friend-copy-actions class="block">
<section class="card-base mt-6 px-6 py-6 sm:px-9" aria-labelledby="friend-apply-title">
	<div class="grid gap-6 lg:grid-cols-[1fr_1.05fr]">
		<div class="rounded-xl border border-black/10 p-5 dark:border-white/10">
			<div class="mb-5 flex items-center gap-4">
				<div class="relative h-20 w-20 overflow-hidden rounded-2xl border border-black/10 bg-black/5 dark:border-white/10 dark:bg-white/5">
					<img src={profileConfig.avatar} alt={profileConfig.name} width="80" height="80" loading="lazy" decoding="async" class="h-full w-full object-cover" />
					<div class="absolute bottom-1 right-1 flex h-6 w-6 items-center justify-center rounded-full bg-[var(--primary)] text-white dark:text-black/75">
						<Icon name="material-symbols:check-circle-outline-rounded" class="text-lg" />
					</div>
				</div>
				<div class="min-w-0">
					<h2 class="truncate text-2xl font-extrabold text-90">{profileConfig.name}</h2>
					<p class="line-clamp-2 text-sm font-medium text-50">{profileConfig.bio}</p>
				</div>
			</div>
			<div class="grid gap-3">
				{applicationFields.map(([label, value]) => (
					<div class="grid grid-cols-[1fr_auto] items-center gap-3 rounded-lg bg-black/[0.04] p-4 dark:bg-white/[0.06]">
						<div class="min-w-0">
							<div class="mb-1 text-sm font-bold text-30">{label}</div>
							<div class="truncate text-base font-extrabold text-75">{value}</div>
						</div>
						<button type="button" data-copy-value={value} aria-label={`${copy.copy}: ${label}`} class="friend-copy-button" title={copy.copy}>
							<Icon name="material-symbols:content-copy-outline-rounded" class="text-xl" />
						</button>
					</div>
				))}
			</div>
		</div>

		<div class="rounded-xl border border-black/10 p-5 dark:border-white/10">
			<div class="mb-6 flex items-center gap-3">
				<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[color-mix(in_oklab,var(--primary)_18%,transparent)] text-[var(--primary)]">
					<Icon name="material-symbols:assignment-turned-in-outline-rounded" class="text-2xl" />
				</div>
				<div>
					<h2 id="friend-apply-title" class="text-2xl font-extrabold text-90">{copy.applyTitle}</h2>
					<p class="mt-1 text-sm font-medium text-50">{copy.applyIntro}</p>
				</div>
			</div>
			<ol class="space-y-5">
				{applySteps.map(([title, body], index) => (
					<li class="grid grid-cols-[2.5rem_1fr] gap-4">
						<div class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--primary)] text-base font-extrabold text-white dark:text-black/75">{index + 1}</div>
						<div>
							<h3 class="text-lg font-extrabold text-90">{title}</h3>
							<p class="mt-1 text-sm font-medium text-50">{body}</p>
							{index === 1 && (
								<div class="mt-3 grid grid-cols-[1fr_auto] gap-3 rounded-lg bg-black/[0.04] p-4 dark:bg-white/[0.06]">
									<pre class="whitespace-pre-wrap text-sm font-bold leading-7 text-75">{applicationTemplate}</pre>
									<button type="button" data-copy-value={applicationTemplate} aria-label={copy.templateTitle} class="friend-copy-button" title={copy.copy}>
										<Icon name="material-symbols:content-copy-outline-rounded" class="text-xl" />
									</button>
								</div>
							)}
						</div>
					</li>
				))}
			</ol>
		</div>
	</div>

	<div class="mt-6 rounded-xl border border-black/10 p-5 dark:border-white/10">
		<div class="mb-4 flex items-center gap-3">
			<Icon name="material-symbols:info-outline-rounded" class="text-2xl text-[var(--primary)]" />
			<h2 class="text-xl font-extrabold text-90">{isZh ? "注意事项" : "Notes"}</h2>
		</div>
		<ul class="grid gap-3">
			{noticeItems.map(([title, body]) => (
				<li class="flex gap-3 text-sm font-medium text-50">
					<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[var(--primary)]"></span>
					<span><strong class="text-75">{title}: </strong>{body}</span>
				</li>
			))}
		</ul>
	</div>
</section>
</friend-copy-actions>

<script is:inline>
	if (!customElements.get("friend-copy-actions")) {
		class FriendCopyActions extends HTMLElement {
			handleCopy = async (event) => {
				const target = event.target;
				const button = target?.closest?.("[data-copy-value]");
				if (!button || !this.contains(button)) return;
				const value = button.dataset.copyValue || "";
				try {
					await navigator.clipboard.writeText(value);
					button.classList.add("is-copied");
					setTimeout(() => button.classList.remove("is-copied"), 1200);
				} catch {
					button.classList.remove("is-copied");
				}
			};

			connectedCallback() {
				this.addEventListener("click", this.handleCopy);
			}

			disconnectedCallback() {
				this.removeEventListener("click", this.handleCopy);
			}
		}
		customElements.define("friend-copy-actions", FriendCopyActions);
	}

	if (!customElements.get("friend-filter")) {
		class FriendFilter extends HTMLElement {
			selectedTag = "all";
			handleInput = () => this.applyFilters();
			handleClick = (event) => {
				const target = event.target;
				const button = target?.closest?.("[data-friend-tag]");
				if (!button || !this.contains(button)) return;
				this.selectedTag = button.dataset.friendTag || "all";
				this.querySelectorAll("[data-friend-tag]").forEach((filter) => {
					const isActive = filter === button;
					filter.classList.toggle("is-active", isActive);
					filter.setAttribute("aria-pressed", String(isActive));
				});
				this.applyFilters();
			};

			connectedCallback() {
				this.querySelector("[data-friend-search]")?.addEventListener("input", this.handleInput);
				this.addEventListener("click", this.handleClick);
			}

			disconnectedCallback() {
				this.querySelector("[data-friend-search]")?.removeEventListener("input", this.handleInput);
				this.removeEventListener("click", this.handleClick);
			}

			applyFilters() {
				const query = (this.querySelector("[data-friend-search]")?.value || "").toLowerCase().trim();
				const cards = this.querySelectorAll("[data-friend-card]");
				let hasVisible = false;
				cards.forEach((card) => {
					const tags = (card.dataset.tags || "").split(",").filter(Boolean);
					const tagMatch = this.selectedTag === "all" || tags.includes(this.selectedTag);
					const searchText = card.dataset.searchText || "";
					const searchMatch = !query || searchText.includes(query);
					const visible = tagMatch && searchMatch;
					card.classList.toggle("hidden", !visible);
					hasVisible ||= visible;
				});
				const empty = this.querySelector("[data-friend-empty]");
				if (empty) {
					empty.classList.toggle("hidden", hasVisible);
					empty.classList.toggle("flex", !hasVisible);
				}
			}
		}
		customElements.define("friend-filter", FriendFilter);
	}
</script>

<style is:global>
	.friends-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
		gap: 0.75rem;
	}

	.friend-filter-chip {
		border-radius: 0.75rem;
		background: color-mix(in oklab, var(--primary) 14%, transparent);
		color: var(--primary);
		font-weight: 800;
		padding: 0.65rem 1rem;
		transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
	}

	.friend-filter-chip:hover {
		transform: translateY(-1px);
		background: color-mix(in oklab, var(--primary) 22%, transparent);
	}

	.friend-filter-chip.is-active {
		background: var(--primary);
		color: white;
	}

	.dark .friend-filter-chip.is-active {
		color: rgb(0 0 0 / 0.75);
	}

	.friend-copy-button {
		display: inline-flex;
		width: 2.75rem;
		height: 2.75rem;
		align-items: center;
		justify-content: center;
		border-radius: 0.625rem;
		background: color-mix(in oklab, var(--primary) 12%, transparent);
		color: var(--primary);
		transition: background-color 0.2s ease, transform 0.2s ease;
	}

	.friend-copy-button:hover,
	.friend-copy-button.is-copied {
		background: var(--primary);
		color: white;
	}

	.dark .friend-copy-button:hover,
	.dark .friend-copy-button.is-copied {
		color: rgb(0 0 0 / 0.75);
	}
</style>
