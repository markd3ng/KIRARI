---
import type { GetStaticPaths } from "astro";
import ArchivePanel from "@components/ArchivePanel.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList, getTaxonomyDisplayMappings } from "../../../utils/content-utils";
import {
	fromLangSlug,
	getEnabledLanguages,
	getPathAlternates,
	toLangSlug,
	withLangPrefix,
} from "../../../utils/i18n-utils";
import { normalizeMappingKey } from "../../../utils/normalize";
import { getTagName } from "../../../utils/url-utils";

export const getStaticPaths = (async () => {
	const paths = [];
	for (const lang of getEnabledLanguages()) {
		const posts = await getSortedPostsList(lang);
		const allTags = new Set<string>();
		posts.forEach((post) => {
			post.data.tags.forEach((tag) => allTags.add(normalizeMappingKey(tag)));
		});
		for (const tag of allTags) {
			paths.push({
				params: { lang: toLangSlug(lang), tag },
				props: { lang, tag },
			});
		}
	}
	return paths;
}) satisfies GetStaticPaths;

const lang = fromLangSlug(Astro.params.lang);
const tag = Astro.params.tag as string;
const posts = await getSortedPostsList(lang);
const { tags: tagDisplayMap } = await getTaxonomyDisplayMappings(lang);
const normalizedTag = normalizeMappingKey(tag);
const filteredPosts = posts.filter((post) =>
	post.data.tags.some((item) => normalizeMappingKey(item) === normalizedTag),
);
const tagName = getTagName(tag, tagDisplayMap);
const tagUrl = withLangPrefix(`/tags/${normalizedTag}/`, lang);
const alternates = getPathAlternates((itemLang) => withLangPrefix(`/tags/${normalizedTag}/`, itemLang));
---

<MainGridLayout title={`${i18n(I18nKey.archive, lang)} - ${tagName}`} lang={lang} alternates={alternates} canonicalUrl={tagUrl}>
	<ArchivePanel sortedPosts={filteredPosts} tagDisplayMap={tagDisplayMap} lang={lang}></ArchivePanel>
</MainGridLayout>
