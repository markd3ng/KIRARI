---
import ArchivePanel from "@components/ArchivePanel.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Config } from "../constants";
import { getSortedPostsList, getTaxonomyDisplayMappings } from "../utils/content-utils";
import { getPathAlternates, withLangPrefix } from "../utils/i18n-utils";

const lang = Config.i18n.defaultLang;
const sortedPostsList = await getSortedPostsList(lang);
const { tags: tagDisplayMap } = await getTaxonomyDisplayMappings(lang);
const archiveUrl = withLangPrefix("/archive/", lang);
const alternates = getPathAlternates((itemLang) => withLangPrefix("/archive/", itemLang));
---

<MainGridLayout title={i18n(I18nKey.archive, lang)} lang={lang} alternates={alternates} canonicalUrl={archiveUrl}>
	<ArchivePanel sortedPosts={sortedPostsList} tagDisplayMap={tagDisplayMap} lang={lang}></ArchivePanel>
</MainGridLayout>
