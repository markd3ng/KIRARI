---
import ArchivePanel from "@components/ArchivePanel.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getSortedPostsList,
	getTaxonomyDisplayMappings,
} from "@utils/content-utils";
import { normalizeMappingKey } from "@utils/normalize";
import { getCategoryName } from "@utils/url-utils";


export async function getStaticPaths() {
	const posts = await getSortedPostsList();
	const allCategories = new Set<string>();
	posts.forEach((post) => {
		const category = post.data.category;
		if (category && normalizeMappingKey(category) !== "") {
			allCategories.add(normalizeMappingKey(category));
		} else {
			allCategories.add("uncategorized");
		}
	});

	return Array.from(allCategories).map((category) => {
		return {
			params: { category },
		};
	});
}

const { category } = Astro.params as { category: string };

const posts = await getSortedPostsList();
const { categories: categoryDisplayMap, tags: tagDisplayMap } =
	await getTaxonomyDisplayMappings();
const normalizedCategory = normalizeMappingKey(category);
const filteredPosts = posts.filter((p) => {
	const postCat = p.data.category;
	if (normalizedCategory === "uncategorized") {
		return !postCat || normalizeMappingKey(postCat) === "";
	}
	return postCat && normalizeMappingKey(postCat) === normalizedCategory;
});

const categoryName =
	category === "uncategorized"
		? i18n(I18nKey.uncategorized)
		: getCategoryName(category, categoryDisplayMap);

---

<MainGridLayout title={`${i18n(I18nKey.archive)} - ${categoryName}`}>
    <ArchivePanel sortedPosts={filteredPosts} tagDisplayMap={tagDisplayMap}></ArchivePanel>

</MainGridLayout>
