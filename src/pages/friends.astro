---
import { render } from "astro:content";
import FriendLinksPanel from "@components/friends/FriendLinksPanel.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import friendsItems from "../_data/friends.json";
import { Config } from "../constants";
import { getLocalizedSpecEntry } from "../utils/spec-content";
import { getPathAlternates, withLangPrefix } from "../utils/i18n-utils";

const lang = Config.i18n.defaultLang;
const friendsPage = await getLocalizedSpecEntry("friends", lang);
if (!friendsPage) throw new Error("Friends page content not found");
const { Content } = await render(friendsPage);
const friendsUrl = withLangPrefix("/friends/", lang);
const alternates = getPathAlternates((itemLang) => withLangPrefix("/friends/", itemLang));
const items = friendsItems;
---

<MainGridLayout title={i18n(I18nKey.friends, lang)} description={i18n(I18nKey.friends, lang)} lang={lang} alternates={alternates} canonicalUrl={friendsUrl}>
	<FriendLinksPanel items={items} lang={lang} />
	<div class="card-base mt-6 px-6 py-6 sm:px-9">
		<Markdown class="">
			<Content />
		</Markdown>
	</div>
</MainGridLayout>
