# Site Configuration
# Copy this file to .env.local and fill in your values

# Your site's URL (used for sitemap and SEO)
PUBLIC_SITE_URL=https://markd3ng.github.io

# Your site's title
PUBLIC_SITE_TITLE=KIRARI

# Your site's subtitle
PUBLIC_SITE_SUBTITLE=Demo Site

# Banner credit configuration
# Set to "true" to enable banner credit display
PUBLIC_BANNER_CREDIT_ENABLE=false
PUBLIC_BANNER_CREDIT_TEXT=
PUBLIC_BANNER_CREDIT_URL=

# Analytics (optional)
# Master switch, analytics will only load when this is true and build is production
PUBLIC_ANALYTICS_ENABLE=false
PUBLIC_GOOGLE_ANALYTICS_ID=
PUBLIC_UMAMI_ID=
PUBLIC_UMAMI_SRC=
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=
# Clarity supports both keys, PUBLIC_CLARITY_PROJECT_ID takes precedence
PUBLIC_CLARITY_PROJECT_ID=
PUBLIC_CLARITY_ID=
PUBLIC_FATHOM_SITE_ID=
PUBLIC_SIMPLE_ANALYTICS_DOMAIN=
PUBLIC_MATOMO_SITE_ID=
PUBLIC_MATOMO_SRC=
PUBLIC_AMPLITUDE_API_KEY=

# SEO / IndexNow
PUBLIC_INDEXNOW_KEY=
