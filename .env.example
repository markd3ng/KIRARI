# Copy this file to .env.local and fill in your values
# KIRARI is TOML-first. Put normal site settings in kirari.config.toml.
# Use env for provider credentials, secrets, and deploy-specific overrides.

# Analytics (optional)
# Master switch, analytics will only load when this is true and build is production
PUBLIC_ANALYTICS_ENABLE=false
PUBLIC_GOOGLE_ANALYTICS_ID=
PUBLIC_UMAMI_ID=
PUBLIC_UMAMI_SRC=
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=
# Clarity supports both keys, PUBLIC_CLARITY_PROJECT_ID takes precedence
PUBLIC_CLARITY_PROJECT_ID=
PUBLIC_CLARITY_ID=
PUBLIC_FATHOM_SITE_ID=
PUBLIC_SIMPLE_ANALYTICS_DOMAIN=
PUBLIC_MATOMO_SITE_ID=
PUBLIC_MATOMO_SRC=
PUBLIC_AMPLITUDE_API_KEY=

# SEO / IndexNow
PUBLIC_INDEXNOW_ENABLE=false
PUBLIC_INDEXNOW_KEY=

# Google Indexing API (advanced, optional)
# Store the full service account JSON in this private env var.
GOOGLE_INDEXING_SERVICE_ACCOUNT_JSON=
